{
  "profile": {
    "name": "dev"
  },
  "active_provider": "anthropic",
  "providers": {
    "anthropic": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-20250514",
      "stream": true,
      "api_key": "sk-ant-...",
      "base_url": "https://api.anthropic.com",
      "auth": "x-api-key",
      "api_version": "2023-06-01"
    },
    "openai": {
      "provider": "openai",
      "model": "gpt-4.1",
      "stream": true,
      "api_key": "sk-...",
      "base_url": "https://api.openai.com/v1"
    },
    "local": {
      "provider": "openai_compatible",
      "model": "local-model-name",
      "stream": true,
      "api_key": "not-needed",
      "base_url": "http://127.0.0.1:11434/v1"
    }
  },
  "modules": {
    "workflow": "coding.plan_execute_review",
    "search": "null",
    "memory": "none",
    "memory_policy": "none",
    "context": "simple",
    "policy": "ask_write",
    "patch": "null",
    "compactor": "none",
    "tool_exposure": "all_visible",
    "renderer": "statusline"
  },
  "module_config": {
    "policy": {
      "ask_write": {
        "ask_before": ["apply_patch", "remember_fact"],
        "allow": ["search", "request_user_input"]
      }
    },
    "search": {
      "rg": {
        "max_results": 50
      }
    },
    "context": {
      "simple": {
        "max_search_results": 50
      },
      "repo_aware": {
        "providers": [
          "project_instructions",
          "manifest",
          "git_status",
          "repo_tree",
          "memory",
          "search"
        ],
        "max_context_bytes": 60000,
        "max_bytes_per_file": 8000,
        "max_search_results": 50,
        "memory_limit": 5,
        "repo_tree_max_entries": 300,
        "repo_tree_max_depth": 3,
        "repo_tree_skip_entries": [
          ".git",
          "target",
          "node_modules",
          ".agent",
          "sessions",
          "dist",
          "build",
          ".env",
          "secrets.json",
          "config.local.json"
        ],
        "project_instruction_files": ["AGENTS.md", "CLAUDE.md", ".cursorrules"],
        "manifest_files": [
          "Cargo.toml",
          "package.json",
          "pyproject.toml",
          "go.mod",
          "pom.xml",
          "build.gradle",
          "composer.json"
        ]
      }
    }
  },
  "tools": {
    "enabled": ["apply_patch", "remember_fact", "request_user_input", "search"],
    "path": null
  },
  "permissions": {
    "mode": "normal"
  },
  "app_server": {
    "approval_timeout_ms": 300000
  },
  "runtime": {
    "model_timeout_ms": 10800000,
    "context_timeout_ms": 30000,
    "workflow_timeout_ms": 14400000
  },
  "event_log": {
    "path": ".agent/events.jsonl"
  }
}
